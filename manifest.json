{
  "manifest_version": 3,
  "name": "Tab Time Machine",
  "version": "0.1.0",
  "description": "Saves and restores tab sessions",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "scripts": ["src/background/index.ts"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"]
}
